# Copia a .env.local o configura en Vercel → Settings → Environment Variables

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Solo servidor (nunca NEXT_PUBLIC_):
SUPABASE_SERVICE_ROLE_KEY=

# Cloudinary (solo estas tres en el servidor; NO uses CLOUDINARY_URL)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Solo para construir URLs en el cliente (mismo valor que CLOUDINARY_CLOUD_NAME)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Cookie de sesión del portal (string largo aleatorio en producción)
AULANUBE_SESSION_SECRET=
